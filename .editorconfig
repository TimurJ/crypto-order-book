# EditorConfig — editor defaults for the files Biome (ts/tsx only) does not cover.
# Biome stays the source of truth for .ts/.tsx; these values mirror it so editors agree.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown uses two trailing spaces as a hard line break — don't strip them.
[*.md]
trim_trailing_whitespace = false
