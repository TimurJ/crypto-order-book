{
  // Isolated project for test files — mirrors how tsconfig.worker.json isolates the Worker's types.
  // Confines vitest globals + jest-dom matcher types to tests (kept out of the app/worker projects),
  // while reusing the app's DOM lib, JSX transform, `@`→src paths, and vite/client (so app modules a
  // test imports — which use `import.meta.env` — still type-check here). Referenced by tsconfig.json
  // so `tsc -b` (pnpm build) type-checks tests too; test files are excluded from tsconfig.app.json
  // so no file is claimed by two projects.
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vitest/globals", "@testing-library/jest-dom", "vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  // NB: tsconfig globs support only * ? ** (no {a,b} brace expansion), so patterns are enumerated.
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/test"
  ]
}
